{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Frontend: Vite Dev Server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/vite",
      "args": ["--host"],
      "cwd": "${workspaceFolder}/apps/web",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Backend: FastAPI (uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--host", "0.0.0.0",
        "--port", "8000"
      ],
      "cwd": "${workspaceFolder}/api-template",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/api-template",
        "ENVIRONMENT": "development"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Backend: pytest (all tests)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v", "--tb=short"],
      "cwd": "${workspaceFolder}/api-template",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Backend: pytest (current file)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${relativeFile}", "-v", "--tb=short"],
      "cwd": "${workspaceFolder}/api-template",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "E2E: Playwright",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/playwright",
      "args": ["test", "--ui"],
      "cwd": "${workspaceFolder}/apps/web",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Frontend + Backend",
      "configurations": [
        "Frontend: Vite Dev Server",
        "Backend: FastAPI (uvicorn)"
      ],
      "stopAll": true
    }
  ]
}
