{
  "name": "@template/platform",
  "version": "2.0.0",
  "packageManager": "pnpm@9.15.9",
  "private": true,
  "description": "Template Platform v2.0 — Supabase-First Monorepo Starter",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @template/web run dev",
    "build": "pnpm run build:packages && pnpm run build:app",
    "build:packages": "pnpm --filter @template/types run build && pnpm --filter @template/shared run build && pnpm --filter @template/design-system run build",
    "build:app": "pnpm --filter @template/web run build",
    "lint": "pnpm --filter @template/web run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:run": "pnpm -r run test:run",
    "storybook": "pnpm --filter @template/design-system run storybook",
    "storybook:build": "pnpm --filter @template/design-system run storybook:build",
    "db:migrate": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "db:types": "npx supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > packages/shared/src/supabase/types.ts",
    "clean": "rimraf node_modules packages/*/node_modules apps/*/node_modules packages/*/dist apps/*/dist apps/web/.next",
    "create-module": "node scripts/new-module.js",
    "setup": "node scripts/setup.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "packages/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "next": "14.2.35",
    "prettier": "^3.8.2",
    "rimraf": "^5.0.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
