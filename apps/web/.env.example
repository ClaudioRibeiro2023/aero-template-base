# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=[CONFIGURE_ME]
NEXT_PUBLIC_SUPABASE_ANON_KEY=[CONFIGURE_ME]
SUPABASE_SERVICE_ROLE_KEY=[CONFIGURE_ME_SERVER_ONLY]

# App Identity
NEXT_PUBLIC_APP_NAME=Template Platform
NEXT_PUBLIC_APP_VERSION=2.0.0
NEXT_PUBLIC_PRIMARY_COLOR=#14b8a6
NEXT_PUBLIC_SECONDARY_COLOR=#0e7490
NEXT_PUBLIC_LOGO_URL=/logo.svg

# Auth Provider: "supabase" (default) or "keycloak"
NEXT_PUBLIC_AUTH_PROVIDER=supabase

# Keycloak (optional — only if NEXT_PUBLIC_AUTH_PROVIDER=keycloak)
# NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
# NEXT_PUBLIC_KEYCLOAK_REALM=my-realm
# NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=my-client
