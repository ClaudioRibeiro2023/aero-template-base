# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=[CONFIGURE_ME]
NEXT_PUBLIC_SUPABASE_ANON_KEY=[CONFIGURE_ME]
SUPABASE_SERVICE_ROLE_KEY=[CONFIGURE_ME_SERVER_ONLY]

# App Identity
NEXT_PUBLIC_APP_NAME=Template Platform
NEXT_PUBLIC_APP_VERSION=2.0.0
NEXT_PUBLIC_PRIMARY_COLOR=#14b8a6
NEXT_PUBLIC_SECONDARY_COLOR=#0e7490
NEXT_PUBLIC_LOGO_URL=/aero-logo.png

# Theme — cores do gradiente (cada app deve ter combinação única)
# Login background: lista de cores CSS separadas por vírgula
NEXT_PUBLIC_GRADIENT_COLORS=#0c2340,#163b5c,#0e8c6b,#0c2340,#1a4a73
# Ambient gradient da área interna (3 cores rgba)
NEXT_PUBLIC_AMBIENT_COLOR_1=rgba(0, 180, 216, 0.06)
NEXT_PUBLIC_AMBIENT_COLOR_2=rgba(167, 139, 250, 0.04)
NEXT_PUBLIC_AMBIENT_COLOR_3=rgba(52, 211, 153, 0.03)

# Auth Provider: "supabase" (default) or "keycloak"
NEXT_PUBLIC_AUTH_PROVIDER=supabase

# Keycloak (optional — only if NEXT_PUBLIC_AUTH_PROVIDER=keycloak)
# NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
# NEXT_PUBLIC_KEYCLOAK_REALM=my-realm
# NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=my-client

# Observability
NEXT_PUBLIC_SENTRY_DSN=           # Sentry DSN (opcional — erros não são reportados sem este)
SENTRY_FORCE_ENABLE=false         # Forçar Sentry em development
