# ============================================
# Infrastructure Environment Variables — v2.0
# ============================================
# Supabase-first: DB and Auth are managed by Supabase Cloud.
# This file configures local dev services only.
# Copy to .env and replace ALL [CONFIGURE_ME] values before use.

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=[CONFIGURE_ME]
NEXT_PUBLIC_SUPABASE_ANON_KEY=[CONFIGURE_ME]
NEXT_PUBLIC_APP_NAME=[CONFIGURE_ME_APP_NAME]
NEXT_PUBLIC_AUTH_PROVIDER=supabase

# Redis (local caching)
REDIS_PORT=6379
REDIS_PASSWORD=[CONFIGURE_ME_MIN_16_CHARS]

# Keycloak (optional — only with docker compose --profile keycloak)
KEYCLOAK_ADMIN=[CONFIGURE_ME]
KEYCLOAK_ADMIN_PASSWORD=[CONFIGURE_ME_MIN_16_CHARS]
KEYCLOAK_HTTP_PORT=8080

# Development
COMPOSE_PROJECT_NAME=[CONFIGURE_ME_PROJECT_NAME]
