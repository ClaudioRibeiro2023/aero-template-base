  },
  "dependencies": {
    "@template/types": "workspace:*",
    "@template/data": "workspace:*",
    "openai": "^4.78.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
